generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  email      String     @unique
  role       String     @default("viewer")
  leads      Lead[]     @relation("AssignedLeads")
  tasks      Task[]
  activities Activity[]
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @default(now()) @updatedAt @map("updated_at")
  password   String?

  @@map("users")
}

model Lead {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  email      String
  phone      String?
  status     String     @default("new")
  assignedTo User?      @relation("AssignedLeads", fields: [assignedId], references: [id])
  assignedId String?    @map("assigned_to") @db.Uuid
  deals      Deal[]
  tasks      Task[]
  activities Activity[]
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @default(now()) @updatedAt @map("updated_at")

  @@map("leads")
}

model Deal {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title     String
  amount    Float
  stage     String   @default("new")
  leadId    String   @db.Uuid
  lead      Lead     @relation(fields: [leadId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("deals")
}

model Task {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String?
  status      String    @default("pending")
  dueDate     DateTime?

  leadId String? @db.Uuid
  lead   Lead?   @relation(fields: [leadId], references: [id])

  userId String? @db.Uuid
  user   User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("tasks")
}

model Activity {
  id   String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type String
  note String?

  leadId String @db.Uuid
  lead   Lead   @relation(fields: [leadId], references: [id])

  userId String? @db.Uuid
  user   User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@map("activities")
}
